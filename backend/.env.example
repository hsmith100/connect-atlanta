# FastAPI Environment Configuration

# Application settings
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=change-me-in-production-connect-key

# Server configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# CORS configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Authentication (if enabled)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis configuration (for caching/background tasks)
REDIS_URL=redis://redis:6379/0

# Monitoring (optional)
SENTRY_DSN=

# Database configuration
DATABASE_URL=postgresql://burger_user:burger_secure_password_123@database:5432/burger_app
